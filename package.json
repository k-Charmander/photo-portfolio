{
  "name": "photo-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "빛과 순간을 담는 사진 포트폴리오 정적 웹사이트",
  "scripts": {
    "dev": "serve -l 8000 .",
    "serve": "serve -l 8000 .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:js": "eslint js",
    "lint:css": "stylelint \"css/**/*.css\"",
    "lint:html": "html-validate index.html",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html",
    "test": "npm run format:check && npm run lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "html-validate": "^9.0.0",
    "prettier": "^3.4.0",
    "serve": "^14.2.4",
    "stylelint": "^16.12.0",
    "stylelint-config-standard": "^36.0.1"
  }
}
